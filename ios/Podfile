require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

ENV['RCT_NEW_ARCH_ENABLED'] = podfile_properties['newArchEnabled'] == 'true' ? '1' : '0'
ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] = podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']

platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'
prepare_react_native_project!
# Ensures that versions from Gemfile is respected
ensure_bundler!

install! 'cocoapods',
  :deterministic_uuids => false

# Firebase must be built as a static framework when use_frameworks! is enabled
$RNFirebaseAsStaticFramework = true if ENV['USE_FRAMEWORKS']

# Helper to build the autolinking config command, used by both target setup and post_install.
def resolve_config_command
  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"]
  else
    [
      'node',
      '--no-warnings',
      '--eval',
      'require(require.resolve(\'expo-modules-autolinking\', { paths: [require.resolve(\'expo/package.json\')] }))(process.argv.slice(1))',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end
end

def common_target_logic
  podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

  use_expo_modules!

  config = use_native_modules!(resolve_config_command)

  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  # Pods for MetaMask
  pod 'ReactNativePayments', :path => '../node_modules/@metamask/react-native-payments/lib/ios/'

  # Pods for Push Notifications
  pod 'FirebaseCore', :modular_headers => true
  pod 'GoogleUtilities/NSData+zlib', :modular_headers => true

  pod 'Permission-BluetoothPeripheral', :path => '../node_modules/react-native-permissions/ios/BluetoothPeripheral'
  pod 'GzipSwift'

  # Fix react-native-quick-crypto build issue: https://github.com/margelo/react-native-quick-crypto/issues/244
  pod 'OpenSSL-Universal', :modular_headers => true

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )
end

target 'MetaMask' do
  common_target_logic
end

target 'MetaMask-QA' do
  common_target_logic
end

target 'MetaMask-Flask' do
  common_target_logic
end

config = use_native_modules!(resolve_config_command)

post_install do |installer|
  react_native_post_install(
    installer,
    config[:reactNativePath],
    :mac_catalyst_enabled => false,
    :ccache_enabled => podfile_properties['apple.ccacheEnabled'] == 'true',
  )

  # Workaround: Disable Folly coroutines to prevent build errors with certain Xcode/clang versions.
  # Can be removed once RCT-Folly ships with coroutines disabled by default for iOS.
  Dir.glob(installer.sandbox.root + "RCT-Folly/folly/Portability.h") do |file|
    begin
      system "chmod +w #{file}"
      contents = File.read(file)
      modified_contents = contents.gsub(/#define FOLLY_HAS_COROUTINES 1/, '#define FOLLY_HAS_COROUTINES 0')
      if !File.writable?(file)
        system "sudo chmod +w #{file}"
      end
      File.write(file, modified_contents)
      system "chmod -w #{file}"
    rescue => e
      Pod::UI.warn "Failed to modify Portability.h: #{e.message}"
    end
  end

  # Disable code signing for resource bundles to prevent signing conflicts on device builds.
  installer.target_installation_results.pod_target_installation_results
    .each do |pod_name, target_installation_result|
    target_installation_result.resource_bundle_targets.each do |resource_bundle_target|
      resource_bundle_target.build_configurations.each do |config|
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      end
    end
  end

  # Enforce minimum iOS deployment target across all pods to silence Xcode warnings
  # about pods targeting older iOS versions than the project.
  min_ios_version = podfile_properties['ios.deploymentTarget'] || '15.1'
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |bc|
      current = bc.build_settings['IPHONEOS_DEPLOYMENT_TARGET']
      if current && Gem::Version.new(current) < Gem::Version.new(min_ios_version)
        bc.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = min_ios_version
      end
    end
  end
end
